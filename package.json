{
  "name": "rakesh-exness",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.8",
"scripts": {
  "dbpush": "cd packages/database && bunx prisma db push && bunx prisma generate",
  "db:generate": "cd packages/database && bunx prisma generate",
  "db:migrate": "bun ./packages/database migrate",
  "backend-dev": "bun --watch ./apps/backend run dev",
  "price-poller-dev": "bun ./apps/price-poller run dev",
  "matching-engine-dev": "bun ./apps/matching-engine run dev",
  "websocket-dev": "bun ./apps/websocket run dev",
  "frontend-dev": "bun --watch ./apps/frontend run dev"
},
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "latest"
  },
  "workspaces": ["apps/*", "packages/*"],
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}